---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = [
  {
    role: t("exp.senior_reclame"),
    company: "Reclame AQUI",
    duration: `mar de 2025 - ${t("exp.present")}`,
    description: t("exp.reclame_desc"),
  },
  {
    role: t("exp.mid_reclame"),
    company: "Reclame AQUI",
    duration: `nov de 2022 - mar de 2025`,
    description: t("exp.reclame_desc"),
  },
  {
    role: t("exp.senior_zappts"),
    company: "Zappts",
    duration: `mai de 2021 - nov de 2022`,
    description: t("exp.zappts_senior_desc"),
  },
  {
    role: t("exp.frontend_zappts"),
    company: "Zappts",
    duration: `mai de 2020 - nov de 2022`,
    description: t("exp.zappts_desc"),
  },
  {
    role: t("exp.frontend_hipr"),
    company: "Hipr Sistemas",
    duration: `out de 2018 - mai de 2020`,
    description: t("exp.hipr_desc"),
  },
  {
    role: t("exp.web_autonomo"),
    company: "Autônomo",
    duration: `ago de 2017 - mai de 2020`,
    description: t("exp.autonomo_desc"),
  },
];
---

<section
  id="experience"
  class="py-20 border-t border-[var(--color-border)]"
  aria-labelledby="experience-heading"
>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
    <div class="md:col-span-4">
      <h2
        id="experience-heading"
        class="text-3xl font-bold tracking-tight text-[var(--color-text)]"
      >
        {t("exp.title")}
      </h2>
    </div>
    <div class="md:col-span-8 space-y-12">
      {
        experiences.map((exp) => (
          <article class="group relative flex flex-col gap-2 pb-1 transition-all">
            <h3 class="text-xl font-semibold text-[var(--color-text)]">
              {exp.role}
            </h3>
            <div class="flex items-center justify-between text-sm text-[var(--color-muted)]">
              <span class="font-medium text-[var(--color-primary)]">
                {exp.company}
              </span>
              <span>{exp.duration}</span>
            </div>
            <p class="mt-2 text-[var(--color-muted)] leading-relaxed font-light text-base">
              {exp.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
