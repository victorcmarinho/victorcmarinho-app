---
<section id="experience" class="py-20 border-t border-zinc-800/60">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
            <h2 class="text-3xl font-bold tracking-tight">Experiência</h2>
        </div>
        <div class="md:col-span-8 space-y-12">
            {experiences.map((exp) => (
                <div class="group relative flex flex-col gap-2 pb-1 transition-all">
                    <h3 class="text-xl font-semibold text-zinc-100">{exp.role}</h3>
                    <div class="flex items-center justify-between text-sm text-zinc-400">
                        <span class="font-medium text-indigo-400">{exp.company}</span>
                        <span>{exp.duration}</span>
                    </div>
                    <p class="mt-2 text-zinc-400 leading-relaxed font-light text-base">
                        {exp.description}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>
