---
const skills = [
  "Astro",
  "Svelte",
  "React",
  "Next.js",
  "Angular",
  "Flutter",
  "TypeScript",
  "Node.js",
  "NestJS",
  "Tailwind CSS",
];
---
<section id="skills" class="py-20 border-t border-zinc-800/60">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
            <h2 class="text-3xl font-bold tracking-tight">Habilidades</h2>
        </div>
        <div class="md:col-span-8 flex flex-wrap gap-3">
             {skills.map((skill) => (
                <span class="px-5 py-2 border border-zinc-800 text-zinc-300 rounded-full text-sm font-medium hover:bg-zinc-800 hover:text-white transition duration-300 cursor-default">
                    {skill}
                </span>
             ))}
        </div>
    </div>
</section>
