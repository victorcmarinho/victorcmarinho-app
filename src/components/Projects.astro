---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface GithubRepo {
  name: string;
  description: string;
  html_url: string;
  language: string;
  updated_at: string;
}

// Fetch the 6 most recently updated public repositories
const response = await fetch(
  "https://api.github.com/users/victorcmarinho/repos?sort=updated&per_page=6",
);
let githubProjects: GithubRepo[] = [];

if (response.ok) {
  githubProjects = await response.json();
} else {
  console.error("Failed to fetch Github repos:", response.statusText);
}

// Map them to match our existing structure, or fallback if fetching fails
const projects =
  githubProjects.length > 0
    ? githubProjects.map((repo) => ({
        name: repo.name,
        description: repo.description || t("projects.no_desc"),
        url: repo.html_url,
        language: repo.language || "Markdown",
      }))
    : [
        {
          name: "EasierDrop",
          description:
            "O Easier Drop é um aplicativo leve e intuitivo que facilita a transferência de arquivos entre pastas no seu computador (macOS).",
          url: "https://github.com/victorcmarinho/EasierDrop",
          language: "Dart",
        },
      ];
---

<section
  id="projects"
  class="py-20 border-t border-[var(--color-border)]"
  aria-labelledby="projects-heading"
>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
    <div class="md:col-span-4">
      <div>
        <h2
          id="projects-heading"
          class="text-3xl font-bold tracking-tight text-[var(--color-text)]"
        >
          {t("projects.title")}
        </h2>
        <p class="mt-4 text-[var(--color-muted)] font-light text-sm">
          {t("projects.subtitle")}
        </p>
      </div>
    </div>
    <ul class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        projects.map((project) => (
          <li>
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block p-6 h-full rounded-2xl border border-[var(--color-border)] hover:bg-[var(--color-border)] transition-all duration-300 focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] outline-none"
            >
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">
                  {project.name}
                </h3>
                <svg
                  class="h-5 w-5 text-[var(--color-muted)] group-hover:text-[var(--color-primary)] transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </div>
              <p class="text-sm font-light text-[var(--color-muted)] mb-4 h-16 overflow-hidden">
                {project.description}
              </p>
              <div class="flex items-center text-xs font-medium text-[var(--color-muted)]">
                <span
                  class="inline-block w-2.5 h-2.5 rounded-full mr-2 bg-[var(--color-primary)] opacity-80"
                  aria-hidden="true"
                />
                {project.language}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Github Contributions Chart -->
  <div
    class="mt-16 flex flex-col gap-4"
    aria-label="Gráfico de contribuições do Github"
  >
    <div class="flex items-center gap-4">
      <h3
        class="text-sm font-semibold text-[var(--color-text)] uppercase tracking-wider"
      >
        {t("projects.contributions")}
      </h3>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>
    <div
      class="rounded-xl p-4 md:p-8 bg-[var(--color-border)]/30 backdrop-blur-sm border border-[var(--color-border)] custom-scrollbar overflow-x-auto flex justify-center"
    >
      <Image
        src="https://ghchart.rshah.org/4070F4/victorcmarinho"
        alt="Gráfico de Commits de Victor Marinho"
        class="min-w-[700px] w-full h-auto opacity-90 hover:opacity-100 transition-opacity"
        loading="lazy"
        decoding="async"
        inferSize={true}
      />
    </div>
  </div>
</section>
