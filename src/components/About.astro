---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
    id="about"
    class="py-20 border-t border-[var(--color-border)]"
    aria-labelledby="about-heading"
>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
            <h2
                id="about-heading"
                class="text-3xl font-bold tracking-tight text-[var(--color-text)]"
            >
                {t("about.title")}
            </h2>
        </div>
        <div
            class="md:col-span-7 space-y-6 text-[var(--color-muted)] leading-relaxed text-lg font-light"
        >
            <p>
                {t("about.grad")}
            </p>
            <p>
                {t("about.exp")}
            </p>
            <p>
                {t("about.ent")}
            </p>
            <p class="font-medium text-[var(--color-text)]">
                {t("about.cert")}
            </p>
        </div>
    </div>
</section>
